\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Visualization of the two main ablations reported in Section~\ref {sec:ablation}. \emph  {PI-GNODE (main)}: uniform edge features. \emph  {$+$ physics edges}: GAT attention conditioned on wind alignment, slope, and NDVI continuity. \emph  {$-$ monotonicity}: inference-time burn-irreversibility floor disabled.}}{6}{figure.caption.14}\protected@file@percent }
\newlabel{fig:ablation}{{3}{6}{Visualization of the two main ablations reported in Section~\ref {sec:ablation}. \emph {PI-GNODE (main)}: uniform edge features. \emph {$+$ physics edges}: GAT attention conditioned on wind alignment, slope, and NDVI continuity. \emph {$-$ monotonicity}: inference-time burn-irreversibility floor disabled}{figure.caption.14}{}}
\@writefile{toc}{\contentsline {section}{\numberline {B}Qualitative Predictions}{6}{appendix.B}\protected@file@percent }
\newlabel{app:qualitative}{{B}{6}{Qualitative Predictions}{appendix.B}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces PI-GNODE predictions on the four NDWS test events with the most fire pixels. Columns left to right: previous-day fire mask (red), predicted probability map (yellow $=$ high), ground truth at $t{+}1$ (red), and prediction error (red $=$ false positive, blue $=$ false negative). The model correctly localizes spread to previously-burning regions plus a narrow expansion zone, consistent with the burn-irreversibility prior. Failures concentrate at the perimeter of fast-spreading events, where the model captures direction but underestimates extent.}}{7}{figure.caption.15}\protected@file@percent }
\newlabel{fig:qual}{{4}{7}{PI-GNODE predictions on the four NDWS test events with the most fire pixels. Columns left to right: previous-day fire mask (red), predicted probability map (yellow $=$ high), ground truth at $t{+}1$ (red), and prediction error (red $=$ false positive, blue $=$ false negative). The model correctly localizes spread to previously-burning regions plus a narrow expansion zone, consistent with the burn-irreversibility prior. Failures concentrate at the perimeter of fast-spreading events, where the model captures direction but underestimates extent}{figure.caption.15}{}}
