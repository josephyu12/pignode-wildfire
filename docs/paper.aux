\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Test-set metrics on Next Day Wildfire Spread. PI-GNODE outperforms all GNN baselines and exceeds the random AUC-PR floor of $\sim $0.013 by $\sim $17$\times $. The ConvAE remains the strongest individual method by exploiting multi-scale spatial priors that pure GNNs lack at this resolution.}}{3}{table.caption.8}\protected@file@percent }
\newlabel{tab:main}{{1}{3}{Test-set metrics on Next Day Wildfire Spread. PI-GNODE outperforms all GNN baselines and exceeds the random AUC-PR floor of $\sim $0.013 by $\sim $17$\times $. The ConvAE remains the strongest individual method by exploiting multi-scale spatial priors that pure GNNs lack at this resolution}{table.caption.8}{}}
