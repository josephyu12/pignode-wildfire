\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces PI-GNODE architecture. The 12-channel input grid is encoded per-cell into hidden state $h(0)$, evolved by stacked edge-conditioned GAT layers parameterizing $dh/dt$, integrated via RK4 over $[0, T]$, decoded to per-cell logits, and floored by the burn-irreversibility prior at inference (eq.~\ref {eq:mono}).}}{2}{figure.caption.7}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:schematic}{{1}{2}{PI-GNODE architecture. The 12-channel input grid is encoded per-cell into hidden state $h(0)$, evolved by stacked edge-conditioned GAT layers parameterizing $dh/dt$, integrated via RK4 over $[0, T]$, decoded to per-cell logits, and floored by the burn-irreversibility prior at inference (eq.~\ref {eq:mono})}{figure.caption.7}{}}
