\@writefile{toc}{\contentsline {subsection}{\numberline {4.1}Main Comparison}{4}{subsection.4.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Test-set metrics on Next Day Wildfire Spread. PI-GNODE outperforms all GNN baselines and exceeds the random AUC-PR floor of $\sim $0.006 (positive class is $<$1\%) by $\sim $37$\times $. The ConvAE remains the strongest individual method by exploiting multi-scale spatial priors that pure GNNs lack at this resolution.}}{4}{table.caption.10}\protected@file@percent }
\newlabel{tab:main}{{1}{4}{Test-set metrics on Next Day Wildfire Spread. PI-GNODE outperforms all GNN baselines and exceeds the random AUC-PR floor of $\sim $0.006 (positive class is $<$1\%) by $\sim $37$\times $. The ConvAE remains the strongest individual method by exploiting multi-scale spatial priors that pure GNNs lack at this resolution}{table.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Validation AUC-PR by epoch. ConvAE saturates higher because its 1.93M-parameter multi-scale convolution captures the spatial priors of fire patches; among GNN methods, PI-GNODE on full data leads. PI-GNODE's strong epoch-1 performance compared to discrete GNN baselines (GAT/GCN) suggests the integrated ODE warm-starts well.}}{4}{figure.caption.11}\protected@file@percent }
\newlabel{fig:curves}{{2}{4}{Validation AUC-PR by epoch. ConvAE saturates higher because its 1.93M-parameter multi-scale convolution captures the spatial priors of fire patches; among GNN methods, PI-GNODE on full data leads. PI-GNODE's strong epoch-1 performance compared to discrete GNN baselines (GAT/GCN) suggests the integrated ODE warm-starts well}{figure.caption.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Ablations}{4}{subsection.4.2}\protected@file@percent }
\newlabel{sec:ablation}{{4.2}{4}{Ablations}{subsection.4.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Ablations on PI-GNODE. Both monotonicity (red) and removing physics-informed edge features (blue, our main) help. Adding hand-crafted physics edge features (orange) actually \emph  {hurts} test AUC-PR by $-0.046$.}}{5}{figure.caption.12}\protected@file@percent }
\newlabel{fig:ablation}{{3}{5}{Ablations on PI-GNODE. Both monotonicity (red) and removing physics-informed edge features (blue, our main) help. Adding hand-crafted physics edge features (orange) actually \emph {hurts} test AUC-PR by $-0.046$}{figure.caption.12}{}}
